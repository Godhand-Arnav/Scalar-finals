# ─── LLM Configuration ──────────────────────────────────────
# Required for standard OpenEnv LLMAgent fallback
OPENAI_API_KEY=""
API_BASE_URL="https://api.groq.com/openai/v1"
MODEL_NAME="llama-3.1-8b-instant"

# Optional: For Hugging Face open weights inference
HF_TOKEN=""

# ─── FREE External Tool APIs ────────────────────────────────
# Get a free key at mediastack.com (500 calls/mo)
MEDIASTACK_API_KEY=""

# Get a free key at gnews.io (100 calls/day)
GNEWS_API_KEY=""

# ─── Local Server ───────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
DATABASE_URL="sqlite:///./forge.db"

# ─── v2.0: Offline Mode & SQLite Cache ──────────────────────
# Set INTERNET_OFF=true to disable all live API calls.
# Tools will exclusively return cached SQLite results.
# Guarantees grading stability without any API keys.
INTERNET_OFF="false"

# Optional: custom path for the tool response cache DB.
# Default: forge_cache.db in the project root.
FORGE_CACHE_DB=""
